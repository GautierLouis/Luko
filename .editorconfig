root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[**/build/**/*.kt]
ktlint = disabled

[**/generated/**/*.kt]
ktlint = disabled

[*.{kt,kts}]
indent_size = 4
ktlint_function_naming_ignore_when_annotated_with = Composable
compose_preview_naming_enabled = true
compose_preview_naming_strategy = prefix
compose_check_modifiers_for_visibility = only_public
compose_allowed_composition_locals = LocalMaterialColors, LocalAppLevelColors, LocalAppStrings, LocalTypography

[*.{yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
